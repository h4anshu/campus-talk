// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

enum PostType {
  DISCUSSION
  SPACE
}

enum SpaceType {
  ANNOUNCEMENTS
  EVENTS
  RESOURCES
  LOST_FOUND
  COLLABORATION
  CONFESSION
}

enum TopicType {
  ACADEMICS
  ASSIGNMENT
  PLACEMENTS
  INTERNSHIP
  CODING
  PROJECTS
  HOSTEL_MESS
  EVENTS
  GENERAL
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum VoteType {
  UP
  DOWN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum UserStatus {
  ACTIVE
  WARNED
  BANNED
}

enum ReportReason {
  SPAM
  MISINFORMATION
  HARASSMENT
  INAPPROPRIATE_CONTENT
  HATE_SPEECH
  PLAGIARISM
  WRONG_CATEGORY
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

model College {
  id            String   @id @default(cuid())
  name          String
  domainPattern String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  users    User[]
  posts    Post[]
  comments Comment[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  image     String?
  banner    String?
  // Nullable: unknown until the student completes onboarding after their
  // first Google sign-in (the NextAuth Prisma adapter creates the row
  // with only id/name/email/image, so these can't be required).
  year      Int?
  dept      String?
  bio       String?
  role      Role     @default(STUDENT)
  reputation Int     @default(0)
  status        UserStatus @default(ACTIVE)
  warningCount  Int        @default(0)
  bannedAt      DateTime?
  bannedReason  String?
  bannedEmail   String?    // set on permanent ban, blocks re-signup
  lastActiveAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]

  collegeId String?
  college   College? @relation(fields: [collegeId], references: [id])

  posts     Post[]
  comments  Comment[]
  votes     Vote[]
  tickets   Ticket[]
  savedPosts SavedPost[]
  notifications      Notification[]
  reputationLogs ReputationLog[]
  reportsMade Report[] @relation("ReportsMade")
}

model BannedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  bannedAt  DateTime @default(now())
  bannedBy  String   // admin userId
}

// --- NextAuth (Auth.js) Prisma adapter models ---
// https://authjs.dev/getting-started/adapters/prisma
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id        String     @id @default(cuid())
  title     String
  body      String     @db.Text
  type      PostType
  space     SpaceType?
  topic     TopicType?
  status    PostStatus @default(PENDING)
  rejectionReason String?
  priority  String?
  anonymous Boolean    @default(false)
  pinned    Boolean    @default(false)
  locked    Boolean    @default(false)
  collabTotalSlots  Int?
  collabFilledSlots Int?       @default(0)
  collabSkills      String[]   @default([])
  collabProjectType String?
  collabDeadline    DateTime?
  collabContact     String?
  collabIsClosed    Boolean    @default(false)
  authorId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  collegeId String?
  college   College? @relation(fields: [collegeId], references: [id])

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  votes     Vote[]
  media     Media[]
  tags      Tag[]
  savedBy   SavedPost[]
  reports   Report[]
  searchVector Unsupported("tsvector")?
}

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  anonymous Boolean  @default(false)
  accepted  Boolean  @default(false)
  authorId  String
  postId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collegeId String?
  college   College? @relation(fields: [collegeId], references: [id])

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  votes     Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  type      VoteType
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model Media {
  id           String   @id @default(cuid())
  type         String   // image | video | youtube | drive
  url          String
  thumbnailUrl String?
  providerId   String?
  postId       String
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[]
}

model SavedPost {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Report {
  id         String       @id @default(cuid())
  reason     ReportReason
  otherText  String?
  status     ReportStatus @default(PENDING)
  postId     String
  reporterId String
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?

  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
}

model Ticket {
  id        String       @id @default(cuid())
  subject   String
  body      String       @db.Text
  type      String       // POST_REQUEST | REPORT | QUERY
  status    TicketStatus @default(OPEN)
  // Tracks only whether admin has ever opened this ticket — the opening
  // message lives on the Ticket row itself (subject/body), not as a
  // TicketMessage, so it needs its own read flag separate from the
  // per-message TicketMessage.isRead below.
  openedByAdmin Boolean  @default(false)
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  body      String   @db.Text
  fromAdmin Boolean  @default(false)
  // Whether the *recipient* (the side that didn't send this message) has
  // seen it yet — flips to true when they open the ticket detail view.
  isRead    Boolean  @default(false)
  ticketId  String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model ReputationLog {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String   // enum-like string key (see lib/reputation.ts ReputationReason)
  refId     String?  // postId / commentId that triggered it
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
enum NotificationType {
  POST_LIKED
  COMMENT_LIKED
  POST_COMMENTED
  COMMENT_REPLIED
  ANSWER_ACCEPTED
  POST_APPROVED
  POST_REJECTED
  TICKET_REPLY
  REPORT_VERIFIED
  COLLAB_SLOT_FILLED
  LOST_FOUND_RETURNED
  ADMIN_WARNING
  REPORT_ACTION_TAKEN
  POST_REMOVED_BY_ADMIN
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  linkUrl   String?          // where to navigate on click
  actorName String?          // who triggered it (null for system events)
  actorImage String?
  refId     String?          // postId / commentId / ticketId
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
